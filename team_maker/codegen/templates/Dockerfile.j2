# Dockerfile — generated by team_maker for the `runner` service.
# Builds the agent team package so it can talk to the `ollama` sidecar on
# the same Docker network (http://ollama:11434).

FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

# Minimal system deps: git for pip VCS installs, curl for healthcheck/debug.
RUN apt-get update && apt-get install -y --no-install-recommends \
        git curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Python deps first to maximise Docker layer caching.
COPY requirements.txt /app/requirements.txt
RUN pip install -r requirements.txt

# Copy the rest of the team package.
COPY . /app

# Pre-create the mount points so compose volumes bind cleanly.
RUN mkdir -p /app/state /app/workspace

CMD ["python", "run_example.py"]
