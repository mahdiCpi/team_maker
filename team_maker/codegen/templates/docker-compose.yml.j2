# docker-compose.yml — generated by team_maker
#
# Two-service stack: `ollama` (model server + init) and `runner` (the agent team).
# The `ollama-init` sidecar pulls every model this team needs on first boot
# (with fallback to the latest known tag when a specific version 404s), then
# exits. `runner` waits for that one-shot pull to complete before starting.
#
# Usage:
#   docker compose up --build
#
# Persisted volumes:
#   ollama_models — weights cache (survives `docker compose down`)

services:
  ollama:
    image: ollama/ollama:latest
    restart: unless-stopped
    volumes:
      - ollama_models:/root/.ollama
    healthcheck:
      test: ["CMD-SHELL", "curl -sf http://localhost:11434/ > /dev/null || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 30
      start_period: 15s
    networks:
      - team_net

  ollama-init:
    image: ollama/ollama:latest
    depends_on:
      ollama:
        condition: service_healthy
    environment:
      OLLAMA_HOST: http://ollama:11434
    entrypoint: ["/bin/sh", "-c"]
    command: >
      "set -e;
{% for model in ollama_models %}
      echo '[init] pulling {{ model }}';
      ollama pull {{ model }} || {
        fallback='{{ model.split(':')[0] }}';
        echo \"[init] tag {{ model }} not found — falling back to $$fallback\";
        ollama pull $$fallback;
      };
{% endfor %}
      echo '[init] all models ready';"
    networks:
      - team_net
    restart: "no"

  runner:
    build:
      context: .
      dockerfile: Dockerfile
    depends_on:
      ollama-init:
        condition: service_completed_successfully
    environment:
      # Cloud provider keys — pass through from host if set (empty otherwise)
      OPENAI_API_KEY: ${{ '{' }}OPENAI_API_KEY:-{{ '}' }}
{% for env_var in cloud_env_vars if env_var != "OPENAI_API_KEY" %}
      {{ env_var }}: ${{ '{' }}{{ env_var }}:-{{ '}' }}
{% endfor %}
      # Where the runner should talk to Ollama
      OLLAMA_HOST: http://ollama:11434
      # Langfuse observability — point at your shared Langfuse server
      LANGFUSE_PUBLIC_KEY: ${LANGFUSE_PUBLIC_KEY:-}
      LANGFUSE_SECRET_KEY: ${LANGFUSE_SECRET_KEY:-}
      LANGFUSE_HOST: ${LANGFUSE_HOST:-http://localhost:3000}
      # Sandbox mode: false inside the compose runner (the container IS the sandbox)
      SANDBOX_ENABLED: "false"
      # Override WORKSPACE_ROOT to point to the mounted volume inside the container
      WORKSPACE_ROOT: /app/workspace
    volumes:
      - ./state:/app/state
      - ./workspace:/app/workspace
    networks:
      - team_net
    restart: "no"

volumes:
  ollama_models:
    name: {{ compose_project }}_ollama_models

networks:
  team_net:
    name: {{ compose_project }}_net
